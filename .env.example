# =============================================================================
# Local dev setup notes
# =============================================================================
# dydx-v4-client install caveat:
#   - On Windows (any modern Python), `pip install -r requirements.txt` will
#     likely fail on dydx-v4-client because its native dep `ed25519-blake2b`
#     requires MSVC Build Tools and has no prebuilt wheel for this platform.
#   - This is EXPECTED for local Windows dev. Tests mock the dYdX SDK, so the
#     core test suite runs fine without it installed.
#   - Workarounds for a full local install (optional):
#       * Use Docker or WSL2 (recommended)
#       * Install Microsoft C++ Build Tools so the native ext can compile
#   - Production target (Linux / Fly.io): installs cleanly, no action needed.
# =============================================================================

AUTH_USER=admin
AUTH_PASS=changeme
WALLET_ADDRESS=0x...
WALLET_PRIVATE_KEY=0x...
ARBITRUM_RPC_URL=https://arb1.arbitrum.io/rpc
ARBITRUM_RPC_FALLBACK=
CLM_VAULT_ADDRESS=0x...
CLM_POOL_ADDRESS=0x...
DYDX_MNEMONIC="word1 word2 ... word24"
DYDX_ADDRESS=dydx1...
DYDX_NETWORK=mainnet
DYDX_SUBACCOUNT=0
DYDX_SYMBOL=ETH-USD
POOL_TOKEN0_SYMBOL=WETH
POOL_TOKEN1_SYMBOL=USDC
POOL_TOKEN1_IS_STABLE=true
POOL_TOKEN1_USD_PRICE=1.0
HEDGE_RATIO=1.0
MAX_OPEN_ORDERS=200
THRESHOLD_AGGRESSIVE=0.01
ALERT_WEBHOOK_URL=
ACTIVE_EXCHANGE=dydx
DB_PATH=automoney.db

# Phase 2.0 on-chain execution
UNISWAP_V3_ROUTER_ADDRESS=0xE592427A0AEce92De3Edee1F18E0157C05861564
# Pair tokens (defaults; pair picker overrides at runtime)
TOKEN0_ADDRESS=0x82aF49447D8a07e3bd95BD0d56f35241523fBab1   # WETH default
TOKEN1_ADDRESS=0xaf88d065e77c8cC2239327C5EDb3A432268e5831   # USDC native (Arbitrum)
TOKEN0_DECIMALS=18
TOKEN1_DECIMALS=6
SLIPPAGE_BPS=30
UNISWAP_V3_POOL_FEE=500
